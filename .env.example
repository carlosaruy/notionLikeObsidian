# ============================================
# NOTION TOKEN - LOCAL ONLY, NEVER COMMIT
# ============================================
# Create an Internal Integration at:
# https://www.notion.so/profile/integrations
#
# Then share the pages/databases you want to graph with the integration.

# For development proxy (token stays on your machine)
NOTION_TOKEN=ntn_your_token_here

# Optional: If you want to test the frontend sending the token directly (less secure)
# VITE_NOTION_TOKEN=ntn_your_token_here
